{
  "name": "lakshyanew",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.15.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "gen:schema": "node --import ./apps/api/node_modules/tsx/dist/loader.mjs scripts/gen-schema.mjs",
    "gen:resources": "node --import ./apps/api/node_modules/tsx/dist/loader.mjs scripts/gen-schema.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "sharp": "^0.35.3"
  }
}
