        "group": "Account"
      }
    },
    "name": {
      "type": "string",
      "label": "Name",
      "editable": [
        "create",
        "update"
      ],
      "visible": [
        "list",
        "get",
        "create",
        "update"
      ],
      "ui": {
        "columns": true,
        "filterable": true,
