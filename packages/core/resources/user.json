      "default": "user",
      "editable": [
        "create",
        "update"
      ],
      "visible": [
        "list",
        "get",
        "create",
        "update"
      ],
      "ui": {
        "columns": true,
        "filterable": true,
        "render": "badge",
        "group": "Access"
      }
    },
    "roles": {
      "type": "json",
