      "editable": [
        "create",
        "update"
      ],
      "visible": [
        "get",
        "create",
        "update"
      ],
      "ui": {
        "group": "Access",
        "input": "textarea",
        "help": "Raw JSON triple-store grants."
      }
    },
    "permissions": {
      "type": "tags",
      "label": "Permissions",
      "editable": [
        "create",
        "update"
      ],
      "visible": [
        "list",
        "get",
        "create",
        "update"
      ],
      "ui": {
        "group": "Access"
      }
    },
    "status": {
      "type": "enum",
      "label": "Status",
      "options": {
        "active": "Active",
        "inactive": "Inactive",
        "banned": "Banned"
      },
      "default": "active",
      "editable": [
        "create",
        "update"
      ],
      "visible": [
        "list",
        "get",
        "create",
        "update"
      ],
      "ui": {
        "columns": true,
        "filterable": true,
        "render": "badge",
        "group": "Access"
      }
